# I2V-CompBench 环境变量模板
# 用法：复制本文件为 .env 后填入真实密钥
#   cp .env.example .env   (Linux/macOS)
#   Copy-Item .env.example .env   (PowerShell)

# SiliconFlow API Key（Phase 1 VLM/LLM 调用、Phase 2 T2I/VQA 调用都依赖此 key）
SILICONFLOW_API_KEY=sk-your-key-here

# ============================================================
# 可选：模型选型环境变量覆盖（设了即覆盖 yaml，不设则用 yaml 默认）
# 仅推荐个人临时实验使用；正式配置请提交到 configs/phase1.yaml / phase2.yaml
# ============================================================
# VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# LLM_MODEL=deepseek-ai/DeepSeek-V3
# T2I_MODEL=black-forest-labs/FLUX.1-schnell
